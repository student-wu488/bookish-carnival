{
  "manifest_version": 3,
  "name": "净网守护 - 抖音评论过滤",
  "version": "1.0.0",
  "description": "实时过滤抖音评论中的违规内容，AI 驱动的内容安全管理",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://*.douyin.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.douyin.com/*", "https://douyin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
